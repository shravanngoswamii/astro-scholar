---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import AuthorLink from '../components/AuthorLink.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { url } from '../utils/paths';

type Props = CollectionEntry<'blog'>['data'] & { id?: string };

const { title, description, pubDate, updatedDate, heroImage, authors, id } = Astro.props;
const fallbackHero = id ? url(`/blog/${id}.png`) : url('/og.png');
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: 100%;
				max-width: 100%;
				margin: 0;
			}
			.hero-image {
				width: 100%;
				overflow: hidden;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
				max-width: 100%;
				height: auto;
			}

			.blog-container {
				position: relative;
				max-width: 1200px;
				margin: 0 auto;
				display: flex;
				justify-content: center;
			}

			.prose {
				width: 760px;
				max-width: 100%;
				padding: 1rem;
				color: rgb(var(--gray-dark));
			}
			.prose :global(p) {
				text-align: justify;
				hyphens: auto;
			}

			/* Style the remark-toc output */
			.prose :global(h2#table-of-contents) {
				display: none;
			}
			.prose > :global(ul:first-of-type) {
				margin-bottom: 2rem;
				padding: 1rem;
				background: var(--color-bg-offset);
				border: 1px solid var(--color-border);
				border-radius: var(--radius);
				list-style: none;
			}
			.prose > :global(ul:first-of-type) :global(li) {
				margin-bottom: 0.5rem;
			}
			.prose > :global(ul:first-of-type) :global(a) {
				text-decoration: none;
				color: var(--color-text-muted);
			}
			.prose > :global(ul:first-of-type) :global(a:hover) {
				color: var(--color-accent);
			}

			@media (min-width: 1200px) {
				.prose > :global(ul:first-of-type) {
					position: absolute;
					top: 1rem;
					left: calc(50% + 400px); /* Position it to the right of the 760px centered prose */
					width: 250px;
					margin-bottom: 0;
				}
				.prose > :global(ul:first-of-type)::before {
					content: "Table of Contents";
					display: block;
					font-weight: 700;
					margin-bottom: 0.5rem;
					color: var(--color-text-main);
					text-transform: uppercase;
					font-size: 0.8rem;
					letter-spacing: 0.05em;
				}
			}

			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
				font-size: 2.2rem;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.last-updated-on {
				font-style: italic;
			}
			.blog-authors {
				display: flex;
				gap: 0.5rem;
				justify-content: center;
				flex-wrap: wrap;
				margin-top: 0.75rem;
				font-size: 0.9rem;
				color: var(--color-text-muted);
			}
			.blog-authors span {
				font-size: 0.9rem;
			}
			@media (max-width: 768px) {
				.title h1 {
					font-size: 1.6rem;
				}
				.prose {
					padding: 1rem 0.5rem;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage ? (
						<Image width={1020} height={510} src={heroImage} alt={title} />
					) : (
						<img width={1020} height={510} src={fallbackHero} alt={title} />
					)}
				</div>
				<div class="blog-container">
					<div class="prose">
						<div class="title">
							<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						{authors && authors.length > 0 && (
							<div class="blog-authors">
								{authors.map((authorId, i) => (
									<span>
										<AuthorLink nameOrSlug={authorId} />
										{i < authors.length - 1 ? ', ' : ''}
									</span>
								))}
							</div>
						)}
						<hr />
					</div>
					<slot />
					</div>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
