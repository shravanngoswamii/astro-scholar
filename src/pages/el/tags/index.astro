---
import { getCollection } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../../consts';
import { url } from '../../../utils/paths';
import { getLangFromUrl, useTranslations, getPostsForLang } from '../../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const allPosts = await getCollection('blog');
const posts = getPostsForLang(allPosts, lang);
const tags = [...new Set(posts.flatMap((post) => post.data.tags || []))].sort();
---

<!doctype html>
<html lang={lang}>
	<head>
		<BaseHead title={`Tags | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
        <style>
            .tags-container {
                display: flex;
                flex-wrap: wrap;
                gap: 1rem;
                margin-top: 2rem;
            }
            .tag-card {
                padding: 1rem 1.5rem;
                background-color: var(--color-bg-offset);
                border: 1px solid var(--color-border);
                border-radius: 8px;
                text-decoration: none;
                color: var(--color-text-main);
                font-weight: 600;
                font-size: 1.1rem;
                transition: all 0.2s ease;
            }
            .tag-card:hover {
                border-color: var(--color-accent);
                color: var(--color-accent);
                transform: translateY(-2px);
                box-shadow: var(--shadow-sm);
            }
        </style>
	</head>
	<body>
		<Header />
		<main>
			<h1>{t('Tags')}</h1>
            <p style="margin-bottom: 2rem; color: var(--color-text-muted);">
                {t('tags.browseByTopic')}
            </p>
            <div class="tags-container">
                {tags.map((tag) => (
                    <a href={url(`/tags/${tag}`)} class="tag-card">
                        #{tag}
                    </a>
                ))}
                {tags.length === 0 && (
                    <p style="color: var(--color-text-muted);">{t('tags.noTagsFound')}</p>
                )}
            </div>
		</main>
		<Footer />
	</body>
</html>
