---
import '../styles/global.css';
import type { ImageMetadata } from 'astro';
import { SITE_TITLE } from '../consts';
import { url } from '../utils/paths';

interface Props {
	title: string;
	description: string;
	image?: string | ImageMetadata;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

let defaultImg = '/og.png';
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
let currentPath = Astro.url.pathname;
if (currentPath.startsWith(basePath)) {
    currentPath = currentPath.substring(basePath.length);
}
currentPath = currentPath.replace(/^\/|\/$/g, '');

if (currentPath === '') {
    defaultImg = '/og.png';
} else {
    defaultImg = `/${currentPath}.png`;
}

const { title, description, image = defaultImg } = Astro.props;

const resolveImage = (img: string) => {
    if (img.startsWith('http')) return img;
    const base = import.meta.env.BASE_URL.replace(/\/$/, '') + '/';
    if (img.startsWith(base)) return img;
    return `${base}${img.replace(/^\//, '')}`;
};

const imageUrl = typeof image === 'string'
	? new URL(resolveImage(image), Astro.url)
	: new URL(image.src, Astro.url);
---

<meta charset="utf-8" />
<script is:inline>
	(() => {
		const root = document.documentElement;
		const paintTheme = (theme) => {
			const dark = theme === 'dark';
			root.setAttribute('data-theme', dark ? 'dark' : 'light');
			root.style.backgroundColor = dark ? '#0f172a' : '#ffffff';
			root.style.colorScheme = dark ? 'dark' : 'light';
		};
		let theme = 'light';
		try {
			const s = localStorage.getItem('theme');
			if (s === 'dark' || s === 'light') theme = s;
			else if (matchMedia('(prefers-color-scheme: dark)').matches) theme = 'dark';
		} catch {
			if (matchMedia('(prefers-color-scheme: dark)').matches) theme = 'dark';
		}
		paintTheme(theme);
		window.addEventListener('load', () => root.setAttribute('data-theme-ready', 'true'), { once: true });
		window.__setPreferredTheme = paintTheme;
	})();
</script>
<style is:inline>
	/* CSS variables inline — available immediately in all modes (dev + prod), before any external CSS */
	:root {
		--color-bg: #ffffff;
		--color-bg-offset: #ffffff;
		--color-bg-header: rgba(255, 255, 255, 0.85);
		--color-text-main: #1a1a1a;
		--color-text-muted: #555555;
		--color-accent: #003366;
		--color-border: #eaeaea;
	}
	[data-theme='dark'] {
		--color-bg: #0f172a;
		--color-bg-offset: #0f172a;
		--color-bg-header: rgba(15, 23, 42, 0.8);
		--color-text-main: #e2e8f0;
		--color-text-muted: #94a3b8;
		--color-accent: #60a5fa;
		--color-border: #334155;
	}
	html, body { min-height: 100%; background-color: #ffffff; }
	@media (prefers-color-scheme: dark) {
		html:not([data-theme='light']), html:not([data-theme='light']) body { background-color: #0f172a; }
	}
	html[data-theme='dark'], html[data-theme='dark'] body { background-color: #0f172a; color-scheme: dark; }
	html[data-theme='light'], html[data-theme='light'] body { background-color: #ffffff; color-scheme: light; }
	/* Header: higher specificity (0,1,2) beats scoped rule (0,1,1) — no flash even before component CSS loads */
	html[data-theme='dark'] header { background: rgba(15, 23, 42, 0.8) !important; }
	html:not([data-theme='dark']) header { background: rgba(255, 255, 255, 0.85) !important; }
	
	/* Icon toggle FOUC prevention */
	.moon-icon { display: none; }
	.sun-icon { display: block; }
	html[data-theme='dark'] .moon-icon { display: block !important; }
	html[data-theme='dark'] .sun-icon { display: none !important; }
	
	/* Layout FOUC prevention */
	body { margin: 0; }
	header { position: sticky; top: 0; z-index: 100; margin: 0; padding: 0 1em; backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); font-family: 'Atkinson', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; }
	header nav { display: flex; align-items: center; justify-content: space-between; max-width: var(--max-width, 960px); margin: 0 auto; height: 4.5rem; }
	header nav h2 { margin: 0; font-size: 1.3em; margin-top: 0 !important; border: none !important; font-family: inherit; font-weight: 700; letter-spacing: -0.02em; }
	header nav h2 a { text-decoration: none; color: inherit; }
	.internal-links { display: flex; gap: 0.25rem; }
	.internal-links a { padding: 0.5em 0.75em; border-bottom: 2px solid transparent; text-decoration: none; font-size: 0.95rem; font-weight: 500; color: var(--color-text-main); font-family: inherit; }
	.header-actions { display: flex; align-items: center; gap: 0.5rem; }
	.header-actions button { display: flex; align-items: center; justify-content: center; width: 40px; height: 40px; background: transparent; border: none; color: var(--color-text-main); border-radius: 50%; cursor: pointer; }
	#mobile-menu.hidden { display: none !important; }
	@media (min-width: 721px) { #menu-toggle { display: none !important; } .mobile-menu { display: none !important; } }
	@media (max-width: 720px) { .internal-links { display: none !important; } }
	
	/* Suppress all transitions until page is fully styled */
	html:not([data-theme-ready]) *, html:not([data-theme-ready]) *::before, html:not([data-theme-ready]) *::after {
		transition: none !important;
		animation: none !important;
	}
</style>
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href={url('/favicon.svg')} />
<link rel="sitemap" href={url('/sitemap-index.xml')} />
<link
	rel="alternate"
	type="application/rss+xml"
	title={SITE_TITLE}
	href={new URL('rss.xml', Astro.site)}
/>
<meta name="generator" content={Astro.generator} />
<meta name="color-scheme" content="light dark" />

<link rel="preload" href={url('/fonts/atkinson-regular.woff')} as="font" type="font/woff" crossorigin />
<link rel="preload" href={url('/fonts/atkinson-bold.woff')} as="font" type="font/woff" crossorigin />

<link rel="canonical" href={canonicalURL} />

<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={imageUrl} />

<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={imageUrl} />
